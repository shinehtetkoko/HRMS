@model HRMS.Models.AttendanceRecordViewModel
@{
    ViewData["Title"] = "Attendance Records";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-4 w-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold text-dark mb-0 fs-4">Attendance Records</h1>
    </div>
    <div class="card border-light shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">

            <div class="row g-3 align-items-end">

                <div class="col-6 col-sm-4 col-md-2 mini-width-150">
                    <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 label-spacing" data-selected="@Model.SelectedMonth">Month</label>
                    <select id="monthSelect" class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                        <option value="1" selected="@(Model.SelectedMonth == 1)">January</option>
                        <option value="2" selected="@(Model.SelectedMonth == 2)">February</option>
                        <option value="3" selected="@(Model.SelectedMonth == 3)">March</option>
                        <option value="4" selected="@(Model.SelectedMonth == 4)">April</option>
                        <option value="5" selected="@(Model.SelectedMonth == 5)">May</option>
                        <option value="6" selected="@(Model.SelectedMonth == 6)">June</option>
                        <option value="7" selected="@(Model.SelectedMonth == 7)">July</option>
                        <option value="8" selected="@(Model.SelectedMonth == 8)">August</option>
                        <option value="9" selected="@(Model.SelectedMonth == 9)">September</option>
                        <option value="10" selected="@(Model.SelectedMonth == 10)">October</option>
                        <option value="11" selected="@(Model.SelectedMonth == 11)">November</option>
                        <option value="12" selected="@(Model.SelectedMonth == 12)">December</option>
                    </select>
                </div>

                <div class="col-6 col-sm-4 col-md-2 mini-width-150">
                    <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 label-spacing">Year</label>
                    <div class="form-control form-control-sm bg-light text-dark shadow-none py-2 fw-semibold d-flex align-items-center custom-year-box"
                         id="yearDisplay">
                        @Model.SelectedYear
                    </div>
                </div>

                <div class="col-6 col-sm-4 col-md-2 mini-width-150">
                    <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 label-spacing">Department</label>
                    <select id="deptSelect" class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                        <option value="Select Department" selected="@(Model.SelectedDept == "Select Department")">Select Department</option>
                        @if (Model.Departments != null)
                        {
                            foreach (var dept in Model.Departments)
                            {
                                <option value="@dept" selected="@(Model.SelectedDept == dept)">@dept</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-6 col-sm-4 col-md-2 mini-width-150">
                    <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 label-spacing">Employee</label>
                    <select id="employeeSelect" class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                        <option value="Select Employee" selected="@(Model.SelectedEmployee == "Select Employee")">Select Employee</option>
                        @if (Model.Employees != null)
                        {
                            foreach (var emp in Model.Employees)
                            {
                                <option value="@emp" selected="@(Model.SelectedEmployee == emp)">@emp</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-auto d-flex gap-2">
                    <button class="btn btn-primary filter-btn px-4 py-2 fw-medium shadow-sm text-white" onclick="filterRecords()">
                        Filter
                    </button>
                    <button class="btn btn-secondary reset-btn px-4 py-2 fw-medium shadow-sm text-white" onclick="resetRecordsFilter()">
                        Reset
                    </button>
                </div>

                <div class="col col-md text-end ms-auto">
                    <button id="exportExcelBtn" class="btn btn-export-excel fw-bold text-uppercase shadow-sm px-3 d-flex align-items-center justify-content-center">
                         <span class="ms-1">Export to Excel</span>
                    </button>
                </div>

            </div>

            <div class="alert custom-alert-banner border mt-4 mb-0 d-flex align-items-center rounded-3 p-2 px-3 fs-13">
                <span>Showing attendance records from <span class="fw-bold">@Model.DisplayMonthName</span> <span class="fw-bold">@Model.SelectedYear</span></span>
            </div>
        </div>
    </div>

    <input type="hidden" id="currentPage" value="@Model.CurrentPage" />
    <input type="hidden" id="totalPages" value="@Model.TotalPages" />

    <div class="card border-light shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle table-hover m-0 text-start text-nowrap fs-13">
                <thead class="custom-table-thead border-bottom border-light-subtle">
                    <tr class="border-b">
                        <th class="px-4 py-3 border-bottom-0">Employee ID</th>
                        <th class="px-4 py-3 border-bottom-0">Employee Name</th>
                        <th class="px-4 py-3 border-bottom-0">Department</th>
                        <th class="px-4 py-3 border-bottom-0">Date</th>
                        <th class="px-4 py-3 border-bottom-0">Check in</th>
                        <th class="px-4 py-3 border-bottom-0">Check out</th>
                        <th class="px-4 py-3 border-bottom-0">Status</th>
                        <th class="px-4 py-3 border-bottom-0">Total Work Hours</th>
                    </tr>
                </thead>
                <tbody class="custom-table-tbody">
                    @if (Model != null && Model.Attendances != null && Model.Attendances.Any())
                    {
                        foreach (var item in Model.Attendances)
                        {
                            <tr class="border-bottom border-light-subtle @(item.Attendance_Status == "Late" ? "bg-light-subtle" : "")">
                                <td class="px-4 py-3 text-secondary">EMP_@item.User_Id.ToString("D3")</td>
                                <td class="px-4 py-3 fw-medium text-dark">@(item.User?.User_Name ?? "-")</td>
                                <td class="px-4 py-3 text-secondary">@(item.User?.Department?.DepartmentName ?? "-")</td>
                                <td class="px-4 py-3 text-secondary">@item.Attendance_Date.ToString("dd MMM yyyy")</td>
                                <td class="px-4 py-3 text-secondary">@item.Check_In.ToLocalTime().ToString("hh:mm tt")</td>
                                <td class="px-4 py-3 text-secondary">@(item.Check_Out.HasValue? item.Check_Out.Value.ToLocalTime().ToString("hh:mm tt") : "-")</td>

                                <td class="px-4 py-3">
                                    @if (item.Attendance_Status == "Present")
                                    {
                                        <span class="border rounded-pill d-inline-block text-center green-pill">Present</span>
                                    }
                                    else if (item.Attendance_Status == "Late")
                                    {
                                        <span class="border rounded-pill d-inline-block text-center orange-pill">Late</span>
                                    }
                                    else
                                    {
                                        <span class="border rounded-pill d-inline-block text-center red-pill">@item.Attendance_Status</span>
                                    }
                                </td>

                                <td class="px-4 py-3 text-secondary">
                                    @if (item.Check_Out.HasValue)
                                    {
                                        var duration = item.Check_Out.Value - item.Check_In;
                                        <span>@($"{duration.Hours}h {duration.Minutes:D2}m")</span>
                                    }
                                    else
                                    {
                                        <span>0h 00m</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-secondary">No attendance records found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-light p-3 d-flex justify-content-between align-items-center border-top">
            <p class="text-secondary mb-0 fs-13">Showing page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong> (@Model.TotalRecords records)</p>

            <nav aria-label="Table navigation">
                <ul class="pagination pagination-sm m-0 gap-1" style="list-style: none; display: flex; padding-left: 0;">

                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <span class="page-item">
                            <button class="btn btn-sm btn-outline-secondary text-dark previous-btn px-3 py-1"
                                    onclick="changePage(@(Model.CurrentPage - 1))"
                                    style="@(Model.CurrentPage <= 1 ? "cursor: not-allowed !important; opacity: 0.5;" : "cursor: pointer;")"
                                    @(Model.CurrentPage <= 1 ? "disabled" : "")>
                                Previous
                            </button>
                        </span>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <span class="page-item">
                                <button class="btn btn-sm @(Model.CurrentPage == i ? "btn-primary custom-btn text-white" : "btn-outline-secondary text-dark") px-3 py-1 fw-medium"
                                        onclick="changePage(@i)"
                                        style="border-radius: 6px;">
                                    @i
                                </button>
                            </span>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <span class="page-item">
                            <button class="btn btn-sm btn-outline-secondary text-dark next-btn px-3 py-1"
                                    onclick="changePage(@(Model.CurrentPage + 1))"
                                    style="@(Model.CurrentPage >= Model.TotalPages ? "cursor: not-allowed !important; opacity: 0.5;" : "cursor: pointer;")"
                                    @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")>
                                Next
                            </button>
                        </span>
                    </li>

                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/modules/attendance.js"></script>
}
