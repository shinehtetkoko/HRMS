@model HRMS.Models.Attendance.DailyCheckInViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-center p-3 w-100 flex-grow-1" style="min-height: calc(100vh - 70px);">

    <div class="col-12 col-md-9 col-lg-7 col-xl-6 bg-white p-4 p-md-5 rounded-3 border shadow-sm mx-auto">

        <div class="mb-4">
            <h1 class="fs-4 fw-bold m-0">Daily Check-in/Check-out</h1>
            <hr class="mt-3 text-secondary opacity-25">
        </div>

        <form id="checkForm" method="post" enctype="multipart/form-data" class="text-sm" onsubmit="event.preventDefault();">

            <div class="row align-items-center mb-4">
                <label class="col-sm-4 fw-semibold mb-2 mb-sm-0" ">Work Location:</label>
                <div class="col-sm-8 d-flex align-items-center gap-4 fw-medium">
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="workLocation" value="office" checked onchange="toggleLocation()" class="form-check-input mt-0">
                        <span>Office</span>
                    </label>
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="workLocation" value="field" onchange="toggleLocation()" class="form-check-input mt-0">
                        <span>Field</span>
                    </label>
                </div>
            </div>

            <div class="row align-items-center mb-4">
                <label class="col-sm-4 fw-semibold mb-2 mb-sm-0">Check-in Mode:</label>
                <div class="col-sm-8 ">
                    <input type="text" id="checkInMode" value="Standard" readonly
                           class="form-control py-2 px-3 fw-medium bg-light border border-secondary border-opacity-25">
                </div>
            </div>

            <div id="attachmentSection" class="row align-items-center mb-4 d-none">
                <label class="col-sm-4 fw-semibold mb-2 mb-sm-0">Attachment / Selfie:</label>
                <div class="col-sm-8">
                    <div class="input-group border border-secondary border-opacity-25 rounded bg-light overflow-hidden">
                        <label class="btn btn-white bg-white border-end border-secondary border-opacity-25 text-dark px-2 py-2 mb-0 fw-semibold" id="uploadLabel">
                            Choose File
                            <input type="file" id="fileInput" accept=".jpg,.jpeg,.png" class="d-none" onchange="document.getElementById('fileNameSpan').innerText = this.files[0] ? this.files[0].name : 'No file chosen';">
                        </label>
                        <span id="fileNameSpan" class="text-muted px-3 py-2 text-truncate">No file chosen</span>
                    </div>
                    <div id="attachment-error" class="text-danger small mt-2 d-none">Selfie required for Field work.</div>

                    <div id="filetype-error" class="text-danger small mt-2 d-none">Use JPG or PNG formats only.</div>     
                </div>
            </div>

            <div id="locationSection" class="row mb-4 d-none">
                <label class="col-sm-4 fw-semibold mb-2 mb-sm-2 pt-1">Location Details:</label>
                <div class="col-sm-8">
                    <textarea id="locationDetails" rows="3" placeholder="Enter location details..."
                              class="form-control bg-white border border-secondary border-opacity-25"></textarea>
                    <div id="location-error" class="text-danger small mt-2 d-none">Location details required for Field work.</div>    
                </div>
            </div>

            <div class="pt-2 row g-3">
                <div class="col-6">
                    <button type="button" id="checkInBtn"   
                            class="btn w-100 text-white fw-bold py-3 text-uppercase shadow-sm @(ViewBag.IsAlreadyCheckedIn ? "opacity-50" : "")"
                            @(ViewBag.IsAlreadyCheckedIn ? "disabled" : "") onclick="validateCheckIn()">Check In    
                    </button>
                </div>

                <div class="col-6">
                    <button type="button" id="checkOutBtn"
                            class="btn w-100 text-white fw-bold py-3 text-uppercase @(!ViewBag.IsAlreadyCheckedIn ? "opacity-50" : "")"
                            @(!ViewBag.IsAlreadyCheckedIn ? "disabled" : "")
                            onclick="validateCheckOut()">Check Out</button> 
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/attendance.js"></script>
}
