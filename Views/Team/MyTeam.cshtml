@model HRMS.Models.MyTeamViewModel
@{
    ViewData["Title"] = "My Team";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-4 w-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fs-4 fw-bold m-0">My Team</h1>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 p-4 bg-white kpi-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-primary-subtle text-primary shrink-0">
                        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted fw-semibold small text-uppercase mb-1">Pending Leave Requests</p>
                        <h3 class="fw-bold text-dark m-0">@Model.PendingLeaveCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 p-4 bg-white kpi-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-purple-subtle text-purple shrink-0">
                        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted fw-semibold small text-uppercase mb-1">Team Members</p>
                        <h3 class="fw-bold text-dark m-0">@Model.TeamMembersCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 p-4 bg-white kpi-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box bg-info-subtle text-info shrink-0">
                        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted fw-semibold small text-uppercase mb-1">On Leave Today</p>
                        <h3 class="fw-bold text-dark m-0">@Model.OnLeaveTodayCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card p-4 bg-white border-0 shadow-sm mb-4">
        <form id="filterForm" method="get" action="@Url.Action("MyTeam", "Team")">
            <div class="row align-items-end">
                <div class="col-12 col-sm-4 col-md-3 selector">
                    <label for="statusFilter" class="form-label text-muted fw-bold small text-uppercase mb-1 filter-text">Status</label>
                    <select id="statusFilter" name="status" class="form-select bg-light border-0 py-2 outline-none fs-13" onchange="this.form.submit()">
                        <option value="All" selected="@(Model.SelectedStatus == "All")">All Employees</option>
                        <option value="Leave" selected="@(Model.SelectedStatus == "Leave")">On Leave Today</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    <div class="card border-0 shadow-sm mt-4">
        <div class="table-responsive">
            <table class="table align-middle table-hover m-0 text-start text-nowrap">
                <thead class="custom-table-thead border-bottom border-light-subtle">
                    <tr class="border-b">
                        <th class="px-4 py-3 border-bottom-0">Employee ID</th>
                        <th class="px-4 py-3 border-bottom-0">Employee Name</th>
                        <th class="px-4 py-3 border-bottom-0">Department</th>
                        <th class="px-4 py-3 border-bottom-0">Action</th>
                    </tr>
                </thead>
                <tbody class="custom-table-tbody">
                    @if (Model.Employees == null || !Model.Employees.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No records found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var emp in Model.Employees)
                        {
                            <tr class="border-bottom border-light-subtle">
                                <td class="px-4 py-3">@emp.EmployeeId</td>
                                <td class="px-4 py-3">@emp.EmployeeName</td>
                                <td class="px-4 py-3">@emp.Department</td>
                                <td class="px-4 py-3">

                                    <button type="button"
                                            class="btn btn-link text-decoration-none p-0 fw-medium shadow-none text-primary open-popup-btn"
                                            data-id="@emp.EmployeeId">
                                        View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white p-3 d-flex justify-content-between align-items-center border-top">
            <p class="text-muted mb-0 fs-13">Showing page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong> (@Model.TotalRecords records)</p>

            <nav aria-label="Table navigation">
                <ul class="pagination pagination-sm m-0 gap-1" style="list-style: none; display: flex; padding-left: 0;">


                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="btn btn-sm btn-outline-secondary text-dark px-3 py-1"
                           href="@Url.Action("MyTeam", "Team", new { status = Model.SelectedStatus, page = Model.CurrentPage - 1 })"
                           style="@(Model.CurrentPage <= 1 ? "pointer-events: none; opacity: 0.5;" : "")">
                            Previous
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="btn btn-sm @(Model.CurrentPage == i ? "btn-primary text-white" : "btn-outline-secondary text-dark") px-3 py-1 fw-medium"
                               href="@Url.Action("MyTeam", "Team", new { status = Model.SelectedStatus, page = i })"
                               style="border-radius: 6px;">
                                @i
                            </a>
                        </li>
                    }


                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="btn btn-sm btn-outline-secondary text-dark px-3 py-1"
                           href="@Url.Action("MyTeam", "Team", new { status = Model.SelectedStatus, page = Model.CurrentPage + 1 })"
                           style="@(Model.CurrentPage >= Model.TotalPages ? "pointer-events: none; opacity: 0.5;" : "")">
                            Next
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    </div>
</div>
<div id="popupContainer" class="modal fade show" tabindex="-1" style="display: none; background: rgba(0,0,0,0.5); z-index: 1060; position: fixed; top: 0; left: 0; width: 100%; height: 100%; overflow-y: auto; align-items: center; justify-content: center;">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 55rem; width: 100%; margin: 1.75rem auto; padding: 0 1rem;">
        <div id="popupContent" class="modal-content border-0 p-0 m-0 rounded-3 shadow-lg">
        </div>
    </div>
</div>

@{
    ViewData["IsMyTeam"] = true;
}

@section Scripts {

    <script src="~/js/modules/myteam.js"></script>
}
