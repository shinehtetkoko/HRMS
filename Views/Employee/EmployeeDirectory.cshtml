@model HRMS.Models.Employee.DirectoryViewModel
@using HRMS.Enums

@{
    ViewData["Title"] = "Employee Directory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions{
    public string GetAntiXsrfRequestToken()
    {
        return Xsrf.GetAndStoreTokens(Context).RequestToken;
    }
}
<input type="hidden" id="RequestVerificationToken" value="@GetAntiXsrfRequestToken()" />

<div class="p-4 w-100" data-employee-role="@((int)UserRole.Employee)">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="fs-4 fw-bold m-0">Employee Directory</h1>

        <input type="checkbox" id="registerToggle" class="popup-toggle-checkbox d-none" />

        <label for="registerToggle" class="btn text-white px-4 py-2 fw-medium shadow-sm custom-btn cursor-pointer">
            Register Employee
        </label>
        <partial name="~/Views/Employee/RegisterPopup.cshtml" model="new HRMS.Models.Employee.UserRegisterViewModel { Role_Id = (int)UserRole.Employee }" />

    </div>
    <div class="bg-white p-4 rounded-3 border shadow-sm mb-4">
        <div class="d-flex flex-wrap align-items-end justify-content-between w-100 gap-3">

            
            <div class="col-6 col-sm-4 col-md-2 w-150">
                <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 filter-text">Status</label>
                <select id="statusSelect" class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                    <option value="All" selected="@(ViewBag.CurrentStatus == "All")">All Statuses</option>
                    <option value="Active" selected="@(ViewBag.CurrentStatus == "Active" || ViewBag.CurrentStatus == null)">Active Employees</option>
                    <option value="Resigned" selected="@(ViewBag.CurrentStatus == "Resigned")">Resigned/Inactive Employees</option>
                </select>
            </div>

            <div class="col-6 col-sm-4 col-md-2 w-150">
                <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 filter-text">All Departments</label>
                <select id="deptSelect" class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                    <option value="All">All Departments</option>
                    @if (ViewBag.Departments != null)
                    {
                        foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept">@dept</option>
                        }
                    }
                </select>
            </div>
            
            <div class="col-auto d-flex gap-2">
                <button class="btn btn-primary px-4 py-2 text-sm fw-medium shadow-sm filter-btn">Filter</button>
 
                <button class="btn btn-secondary px-4 py-2 text-sm fw-medium shadow-sm reset-btn">Reset</button>               
            </div>

            <div class="ms-md-auto flex-shrink-0 d-flex align-items-center gap-2">

                <label class="btn px-3 d-flex align-items-center justify-content-center shadow-sm text-uppercase fw-bold m-0 cursor-pointer select-none btn-import-excel">
                    <i class="fa-solid fa-chart-simple"></i>
                    <span class="ms-2 tracking-wide">Import Excel</span>
                    <input type="file" accept=".xlsx, .xls" class="d-none" onchange="handleExcelImport(event)">
                </label>

                <button id="exportExcelBtn" class="btn px-3 d-flex align-items-center justify-content-center shadow-sm text-uppercase fw-bold btn-export-excel">
                    <i class="fa-solid fa-download"></i>
                    <span class="ms-2">Export to Excel</span>
                </button>
            </div>

        </div>
    </div>

    <div class="bg-white border border-light-subtle rounded-3 shadow-sm overflow-hiddden m-1">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-start">
                <thead class="custom-table-thead border-bottom border-light-subtle">
                    <tr class="border-b">
                        <th class="px-4 py-3 border-bottom-0">Employee ID</th>
                        <th class="px-4 py-3 border-bottom-0">Employee Name</th>
                        <th class="px-4 py-3 border-bottom-0">Department</th>
                        <th class="px-4 py-3 text-center border-bottom-0">Update Notifications</th>
                        <th class="px-4 py-3 text-center border-bottom-0">Action</th>
                    </tr>
                </thead>
                <tbody id="employeeTableBody" class="custom-table-tbody">
                    
                    <partial name="_EmployeeTablePartial" model="Model.EmployeeDirectoryList" />
                </tbody>

            </table>
        </div>

        @{
            int currentPage = (int)(ViewBag.CurrentPage ?? 1);
            int totalRecords = (int)(ViewBag.TotalRecords ?? 0);
            int totalPages = (int)(ViewBag.TotalPages ?? 1);
            int pageSize = 1; 

            int fromRecord = totalRecords == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
            int toRecord = Math.Min(currentPage * pageSize, totalRecords);
        }

        <div class="table-footer px-4 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <p class="mb-0 text-secondary">
                @if (totalRecords == 0)
                {
                    <span>No records found</span>
                }
                else
                {
                    <span>Showing @fromRecord to @toRecord of @totalRecords records</span>
                }
            </p>
    
            @if (totalPages > 1)
            {
                <div class="btn-group" role="group" aria-label="Pagination" 
                     id="paginationGroup" 
                     data-current="@currentPage" 
                     data-total="@totalPages">
                     
                    @if (currentPage > 1)
                    {
                        <a class="btn btn-outline-secondary" href="@Url.Action("EmployeeDirectory", new { page = currentPage - 1, status = ViewBag.SelectedStatus, department = ViewBag.SelectedDept })">Previous</a>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary disabled">Previous</button>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <button class="btn btn-primary active">@i</button>
                        }
                        else
                        {
                            <a class="btn btn-outline-secondary" href="@Url.Action("EmployeeDirectory", new { page = i, status = ViewBag.SelectedStatus, department = ViewBag.SelectedDept })">@i</a>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <a class="btn btn-outline-secondary" href="@Url.Action("EmployeeDirectory", new { page = currentPage + 1, status = ViewBag.SelectedStatus, department = ViewBag.SelectedDept })">Next</a>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary disabled">Next</button>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/modules/employee.js"></script>
}