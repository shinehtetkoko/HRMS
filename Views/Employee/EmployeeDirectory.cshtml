@model IEnumerable<HRMS.Models.Admin.HRDirectoryViewModel>
@{
    ViewData["Title"] = "Employee Directory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="p-4 w-100">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="fs-4 fw-bold m-0">Employee Directory</h1>

        <input type="checkbox" id="registerToggle" class="popup-toggle-checkbox d-none" />

        <label for="registerToggle" class="btn text-white px-4 py-2 fw-medium shadow-sm custom-btn cursor-pointer">
            Register Employee
        </label>
        <partial name="~/Views/Employee/RegisterPopup.cshtml" model="new HRMS.Models.Employee.UserRegisterViewModel { Role_Id = 3 }" />

    </div>
    <div class="bg-white p-4 rounded-3 border shadow-sm mb-4">
        <div class="d-flex flex-wrap align-items-end justify-content-between w-100 gap-3">

            
            <div class="col-6 col-sm-4 col-md-2 w-150">
                <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 filter-text">Status</label>
                <select class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                    <option value="All">All Statuses</option>
                    <option value="Active" selected>Active Employees</option>
                    <option value="Resigned">Resigned/Inactive Employees</option>
                </select>
            </div>

            <div class="col-6 col-sm-4 col-md-2 w-150">
                <label class="form-label text-secondary fw-semibold text-uppercase m-0 mb-1 filter-text">All Departments</label>
                <select class="form-select form-select-sm bg-light text-dark shadow-none py-2 fs-13">
                    <option>IT</option>
                    <option>HR</option>
                </select>
            </div>
            <!-- Action Buttons (Filter & Reset) -->
            <div class="col-auto d-flex gap-2">
                <button class="btn btn-primary px-4 py-2 text-sm fw-medium shadow-sm filter-btn">
                    Filter
                </button>
                <button class="btn btn-secondary px-4 py-2 text-sm fw-medium shadow-sm reset-btn">
                    Reset
                </button>
            </div>

            <div class="ms-md-auto flex-shrink-0 d-flex align-items-center gap-2">

                <label class="btn px-3 d-flex align-items-center justify-content-center shadow-sm text-uppercase fw-bold m-0 cursor-pointer select-none btn-import-excel">
                    📊 <span class="ms-2 tracking-wide">Import Excel</span>
                    <input type="file" accept=".xlsx, .xls" class="d-none" onchange="handleExcelImport(event)">
                </label>

                <button id="exportExcelBtn" class="btn px-3 d-flex align-items-center justify-content-center shadow-sm text-uppercase fw-bold btn-export-excel">
                    📥 <span class="ms-2">Export to Excel</span>
                </button>

            </div>

        </div>
    </div>

    <div class="bg-white border border-light-subtle rounded-3 shadow-sm overflow-hiddden m-1">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-start">
                <thead class="custom-table-thead border-bottom border-light-subtle">
                    <tr class="border-b">
                        <th class="px-4 py-3 border-bottom-0">Employee ID</th>
                        <th class="px-4 py-3 border-bottom-0">Employee Name</th>
                        <th class="px-4 py-3 border-bottom-0">Department</th>
                        <th class="px-4 py-3 text-center border-bottom-0">Update Notifications</th>
                        <th class="px-4 py-3 text-center border-bottom-0">Action</th>
                    </tr>
                </thead>
                <tbody class="custom-table-tbody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var emp in Model)
                        {
                            <tr class="border-bottom border-light-subtle">
                                <td class="px-4 py-3">@emp.HR_Id</td>

                                <td class="px-4 py-3">@emp.HR_Name</td>

                                <td class="px-4 py-3">@emp.Email</td>

                                <td class="px-4 py-3 text-center">
                                    <span class="text-secondary fst-italic">No requests</span>
                                </td>

                                <td class="px-3 py-3 text-center">
                                    <button onclick="openEditProfileModal('@emp.User_Id')" class="btn btn-custom-blue d-inline-flex align-items-center gap-2 px-3 py-1.5 fw-medium shadow-sm edit-btn">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                        <span>Edit</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-secondary fst-italic">No employee records found.</td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <div class="table-footer px-4 py-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <p class="mb-0 text-secondary">Showing 1 to 10 of 30 records</p>
            <div class="btn-group" role="group" aria-label="Pagination">
                <button class="btn btn-outline-secondary disabled">Previous</button>
                <button class="btn btn-hrms-primary">1</button>
                <button class="btn btn-outline-secondary">2</button>
                <button class="btn btn-outline-secondary">3</button>
                <button class="btn btn-outline-secondary">Next</button>
            </div>
        </div>
    </div>
</div>

