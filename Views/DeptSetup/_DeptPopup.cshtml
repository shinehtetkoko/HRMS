<link href="~/css/site.css" rel="stylesheet" />
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="modal-header border-bottom p-4 pb-3">
                <h5 class="modal-title fw-bold">Department Setup Form</h5>
            </div>
            <div class="modal-body p-4 mt-6 mb-2">
                <div class="alert alert-primary bg-primary bg-opacity-10 border-0 d-flex align-items-center p-3 rounded-3" role="alert">
                    <i class="bi bi-info-circle-fill me-2 fs-5 text-primary"></i>
                    <span class="fw-medium text-primeary">Enter the new department name.</span>
                </div>
                <div class="bg-gradient p-4 rounded-3 border mb-3">
                    <form id="dept-form" onsubmit="saveDepartmentData(event)">
                        <div class="mb-4">
                            <label class="form-label fw-bold"> Department ID <small class="text-secondary fw-normal">(Auto-generated)</small> </label>
                            <input type="text" id="input-dept-id" class="form-control px-3 py-2 bg-light border-0" value="DEPT-001" readonly>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Department Name <span class="text-danger">*</span></label>
                            <input type="text"id="input-dept-name" class="form-control py-2" placeholder="Enter Department Name" required>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" id="cancelBtn" class="btn btn-outline-secondary flex-grow-1 py-1 fw-normal" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" id="saveBtn" class="btn btn-primary flex-grow-1 py-2 fw-normal" onclick="saveDepartmentData(event, '@Url.Action("DeptSetup", "DeptSetup")')">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

