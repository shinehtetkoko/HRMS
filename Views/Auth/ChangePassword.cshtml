@model HRMS.Models.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

@{
    var source = ViewData["Source"]?.ToString();
    bool isForgotPassword = (source == "forgot");
}

<div class="card border-0 shadow-lg rounded-4 p-4 p-sm-5 bg-white login-card-width">

    <div class="text-center mb-4">
        <h1 class="fs-4 fw-bold m-1 mb-2">@(isForgotPassword ? "Reset Password" : "Change Password")</h1>
        <div class="border-bottom mt-3 mb-2" style="border-color: #f3f4f6 !important;"></div>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3" role="alert">
            <div asp-validation-summary="All" class="text-danger m-0 list-unstyled small"></div>
        </div>
    }

    <form id="passwordForm" asp-controller="Auth" asp-action="@(isForgotPassword ? "ResetPassword" : "ChangePassword")" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />

        <div class="mb-3 @(isForgotPassword ? "d-none" : "")">
            <label class="form-label small mb-2 fw-semibold">Current Password</label>
            <div class="input-group">
                <input id="current-password" asp-for="CurrentPassword" type="password"
                       class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label small mb-2 fw-semibold">New Password</label>
            <div class="input-group">
                <input id="new-password" asp-for="NewPassword" type="password" required minlength="8" maxlength="50"
                       class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
            </div>

            <div id="password-error" class="text-danger small mt-2 d-none">
                Password must contain uppercase, lowercase, number and special character.
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label small mb-2 fw-semibold">Confirm Password</label>
            <div class="input-group">
                <input id="confirm-password" asp-for="ConfirmPassword" type="password" required
                       class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
            </div>

            <div id="match-error" class="text-danger small mt-2 d-none">
                New Password and Confirm Password do not match.
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-bold rounded-3 py-2.5 fs-6 shadow-sm">
            @(isForgotPassword ? "Reset Password" : "Update Password")
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/js/modules/auth.js"></script>
}