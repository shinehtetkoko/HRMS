@model HRMS.Models.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="card border-0 shadow-lg rounded-4 p-4 p-sm-5 bg-white login-card-width">

    <div class="text-center mb-4">
        <h1 class="fs-4 fw-bold m-1 mb-2">Change Password</h1>
        <div class="border-bottom"></div>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3" role="alert">
            <div asp-validation-summary="All" class="text-danger m-0 list-unstyled small"></div>
        </div>
    }

    <form id="passwordForm" method="post" asp-controller="Account" asp-action="ChangePassword" asp-antiforgery="true">

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label small mb-2 fw-semibold">Current Password</label>
            <div class="input-group">
                <input asp-for="CurrentPassword" type="password"
                       class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label small mb-2 fw-semibold">New Password</label>
                <div class="input-group">
                    <input asp-for="NewPassword" type="password" required
                           class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
            
                    <div id="password-error" class="text-danger small mt-2 d-none">
                        Password must contain uppercase, lowercase, number and special character.
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label small mb-2 fw-semibold">Confirm Password</label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" required
                               class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="">
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
            
                        <div id="match-error" class="text-danger small mt-2 d-none">
                            New Password and Confirm Password do not match.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold rounded-3 py-2.5 fs-6 shadow-sm">Update Password</button>
                </form>
            </div>