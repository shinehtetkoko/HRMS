@model HRMS.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}
<!-- Login Card -->
<div class="card border-0 shadow-lg mt-5 ms-s p-4 p-sm-5 bg-white rounded-4 login-card-width">
    <div class="text-center mb-4">
        <h1 class="fs-4 fw-bold mb-2">Login</h1>
        <div class="border-bottom mt-3 mb-2" style="border-color: #f3f4f6 !important;"></div>
    </div>

    @* @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3" role="alert">
            <div asp-validation-summary="All" class="text-danger m-0 list-unstyled small"></div>
        </div>
    } *@

    <form id="loginForm" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-medium text-center"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold small mb-2">Email Address</label>
            <input id="email" name="Input.Email" type="email" class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" placeholder="you@example.com" required autofocus />
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold small mb-2">Password</label>
            <input id="password" name="Input.Password" type="password" class="form-control bg-light-subtle text-dark border-secondary-subtle py-2 fs-6 rounded-3" required />
            <span asp-validation-for="Input.Password" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end mb-4">
            <a asp-controller="Auth" asp-action="ForgotPassword" class="text-primary text-decoration-none small fw-medium">Forgot Password?</a>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-bold rounded-3 py-2.5 fs-6 shadow-sm">Sign In</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/modules/auth.js"></script>
}