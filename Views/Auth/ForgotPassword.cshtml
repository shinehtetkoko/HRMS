@model HRMS.Models.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
}

<div class="card border-0 shadow-lg p-4 p-sm-5 bg-white rounded-4 login-card-width">

    <div class="text-center mb-4">
        <h1 class="fs-4 fw-bold mb-2">Reset Password</h1>
        <p class="text-muted small">Enter your registered email.</p>
        <div class="border-bottom"></div>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3" role="alert">
            <div asp-validation-summary="All" class="text-danger m-0 list-unstyled small"></div>
        </div>
    }

    <div id="successBanner" class="alert alert-success py-2 px-3 small rounded-3 mb-3 d-none" role="alert">
        <p class="fw-semibold mb-0">Reset link simulated successfully!</p>
        <p class="small text-success mt-1 mb-0">
            Verification complete. Redirecting you to set a new password...
        </p>
    </div>

    <form id="forgotForm" method="post" asp-controller="Auth" asp-action="ForgotPassword" onsubmit="handleResetRequest(event)">
        <div class="mb-4">
            <label asp-for="Email" class="form-label fw-semibold small mb-2">Email Address</label>
            <input asp-for="Email"
                   type="email"
                   placeholder="e.g. name@example.com"
                   class="form-control form-control-lg bg-light-subtle text-dark border-secondary-subtle fs-6 rounded-3" required>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit"
                    id="submitBtn"
                    class="btn btn-primary btn-lg w-100 fw-semibold rounded-3 py-2 fs-6 shadow-sm">
                Send Reset Link
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-controller="Auth" asp-action="Login" class="text-primary text-decoration-none small fw-semibold">
                Back to Login
            </a>
        </div>
    </div>