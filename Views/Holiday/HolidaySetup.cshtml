@model HRMS.Models.Holiday.HolidayViewModel
@{
    ViewData["Title"] = "Holiday Setup";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-4 w-100">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fs-4 fw-bold m-0">Holidays</h1>
        <label for="popupToggle"
                class="btn text-white px-4 py-2 fw-medium shadow-sm custom-btn cursor-pointer">
            Create Holiday
        </label>
    </div>

    <div class="bg-white border border-light-subtle rounded-3 shadow-sm overflow-hidden m-1">
        <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-start">
                    <thead class="custom-table-thead border-bottom border-light-subtle">
                        <tr>
                            <th class="px-4 py-3 border-bottom-0">Holiday Name</th>
                            <th class="px-4 py-3 border-bottom-0">Start Date</th>
                            <th class="px-4 py-3 border-bottom-0">End Date</th>
                        </tr>
                    </thead>
                    <tbody class="custom-table-tbody">
                    @if (Model != null && Model.Holidays != null && Model.Holidays.Any())
                    {
                        @foreach(var holiday in Model.Holidays)
                        {
                            <tr class="border-bottom border-light-subtle">
                                <td class="px-4 py-3">@holiday.Holiday_Name</td>
                                <td class="px-4 py-3">@holiday.Start_Date.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-3">
                                    @(holiday.Holiday_Type == "SingleDay" ? "-" : holiday.End_Date.ToString("dd/MM/yyyy"))
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-center text-muted">
                                No public holidays found. Click "Create Holiday" to add one.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
             </div>
          </div>
      </div>

<partial name="HolidaySetupPopup" model="new HRMS.Models.Holiday.HolidayViewModel { Start_Date = DateTime.Today, End_Date = DateTime.Today}" />

@section Scripts {
    <script src="~/js/site.js"></script>

    <script src="~/js/modules/holiday.js"></script>
}
