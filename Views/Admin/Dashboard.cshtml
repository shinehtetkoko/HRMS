@{
    ViewData["Title"] = "System Administrator Console";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-4 w-100">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fs-4 fw-bold m-0">System Admin Console</h1>
            <p class="small text-secondary mt-1">Configure company metadata, manage departments, and register HR console accounts.</p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 align-items-stretch">

        @* total departments card *@
        <div class="col">
            <div class="bg-white p-4 rounded-3 border border-light-subtle shadow-sm d-flex align-items-center gap-3 h-100 transition-shadow">
                <div class="p-2 rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 dept-card">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="width: 24px; height: 24px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-secondary fw-bold mb-0">Total Departments</p>
                    <h3 class="fs-4 fw-bold mt-1 mb-0" id="count-departments">6</h3>
                </div>
            </div>
        </div>

        @* registered hr card *@
        <div class="col">
            <div class="bg-white p-4 rounded-3 border border-light-subtle shadow-sm d-flex align-items-center gap-3 h-100 transition-shadow">
                <div class="p-2 rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 hr-card">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="width: 24px; height: 24px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-secondary fw-bold mb-0">Registered HRs</p>
                    <h3 class="fs-4 fw-bold mt-1 mb-0" id="count-hr">3</h3>
                </div>
            </div>
        </div>

        @* active emp card *@
        <div class="col">
            <div class="bg-white p-4 rounded-3 border border-light-subtle shadow-sm d-flex align-items-center gap-3 h-100 transition-shadow">
                <div class="p-2 rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 emp-card">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="width: 24px; height: 24px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-secondary fw-bold mb-0">Active Employees</p>
                    <h3 class="fs-4 fw-bold mt-1 mb-0" id="count-employees">142</h3>
                </div>
            </div>
        </div>

        @* system health card *@
        <div class="col">
            <div class="bg-white p-4 rounded-3 border border-light-subtle shadow-sm d-flex align-items-center gap-3 h-100 transition-shadow">
                <div class="p-2 rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 sys-card">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="width: 24px; height: 24px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-secondary fw-bold mb-0">System Health</p>
                    <h3 class="fs-4 fw-bold mt-1 mb-0">99.9% Up</h3>
                </div>
            </div>
        </div>

    </div>

    
    <div class="bg-white rounded-3 border border-light-subtle shadow-sm p-4 mt-4">
        <h2 class="fs-5 fw-bold text-dark mb-3">Registered HR Accounts</h2>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-start">
                <thead class="custom-table-thead border-bottom border-light-subtle">
                    <tr>
                        <th class="px-4 py-3 border-bottom-0">HR ID</th>
                        <th class="px-4 py-3 border-bottom-0">HR Name</th>
                        <th class="px-4 py-3 border-bottom-0">Department</th>
                        <th class="px-4 py-3 border-bottom-0">Email Address</th>
                        <th class="px-4 py-3 border-bottom-0">Status</th>
                    </tr>
                </thead>
                <tbody id="registered-hr-list" class="custom-table-tbody">
                    <tr class="border-bottom border-light-subtle">
                        <td class="px-4 py-3 fw-bold">HR01</td>
                        <td class="px-4 py-3 fw-bold">Kyaw Swar</td>
                        <td class="px-4 py-3">Human Resources</td>
                        <td class="px-4 py-3">kyawswar@myanmardcr.com</td>
                        <td class="px-4 py-3">
                            <span class="d-inline-block rounded-pill text-center font-medium border text-nowrap green-pill">Active</span>
                        </td>
                    </tr>
                    <tr class="border-bottom border-light-subtle">
                        <td class="px-4 py-3 fw-bold">HR02</td>
                        <td class="px-4 py-3 fw-bold">Aye Aye Tint</td>
                        <td class="px-4 py-3">Recruitment Section</td>
                        <td class="px-4 py-3">ayeaye@myanmardcr.com</td>
                        <td class="px-4 py-3">
                            <span class="d-inline-block rounded-pill text-center font-medium border text-nowrap green-pill">Active</span>
                        </td>
                    </tr>
                    <tr class="border-bottom border-light-subtle">
                        <td class="px-4 py-3 fw-bold">HR03</td>
                        <td class="px-4 py-3 fw-bold">Mya Sabai</td>
                        <td class="px-4 py-3">Talent Acquisition</td>
                        <td class="px-4 py-3">myasabai@myanmardcr.com</td>
                        <td class="px-4 py-3">
                            <span class="d-inline-block rounded-pill text-center font-medium border text-nowrap green-pill">Active</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>


</div>

